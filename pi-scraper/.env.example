SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

TELEGRAM_BOT_TOKEN=
# Optional fallback when a filter has no chat_id (shouldn't happen in normal flow).
TELEGRAM_CHAT_ID=

USER_AGENT=Mozilla/5.0 (X11; Linux aarch64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Use headless Chromium instead of plain fetch (needed when Idealista blocks).
USE_HEADLESS=0

# Dry-run: scrape + log, but don't write notifications/send Telegram.
DRY_RUN=0
