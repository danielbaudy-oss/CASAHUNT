SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

TELEGRAM_BOT_TOKEN=
# Fallback chat id for MVP single-user mode (later: per-filter via DB)
TELEGRAM_CHAT_ID=

# MVP: one hard-coded search URL. Later: iterate casahunt.filters.
SEARCH_URL=https://www.idealista.com/alquiler-viviendas/barcelona-barcelona/

USER_AGENT=Mozilla/5.0 (X11; Linux aarch64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Use headless Chromium instead of plain fetch (needed when Idealista blocks).
USE_HEADLESS=0

# Dry-run: scrape + log, but don't write to DB or send Telegram.
DRY_RUN=0
